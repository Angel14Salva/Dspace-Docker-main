# Ignore compiled Java files
target/

# Ignore IDE files
.idea/
.vscode/
*.iml
*.ipr
*.iws
.settings/
.project
.classpath

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore logs
*.log
logs/

# Ignore temporary files
*.tmp
*.bak
*.swp
*~

# Ignore local environment overrides (use .env for custom settings)
# NOTE: .env is NOT ignored so users can commit their own configuration
# Use .env.example as template and rename to .env

# Ignore docker volumes (optional - comment out if you want to track data)
# volume_data/
# postgres_data/
